{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },

    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "ios": {
        "simulator": true
      }
    },

    "staging": {
      "distribution": "internal",
      "environment": "preview",
      "channel": "staging"
    },

    "production": {
      "autoIncrement": true,
      "environment": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6790709441"
      }
    }
  }
}

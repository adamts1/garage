# Supabase → Project Settings → Data API / API Keys
# Copy this file to .env.local and fill in your project's values.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Sentry → Project Settings → Client Keys (DSN).
# Optional: leave unset and error tracking stays off (dev, CI).
# Set it in the production build environment.
VITE_SENTRY_DSN=
